{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Nexus",
  "colors": {
    "primary": "#1E3A8A",
    "light": "#4169E1",
    "dark": "#1E3A8A"
  },
  "modeToggle": {
    "default": "dark"
  },
  "favicon": "/icon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Instrumentation",
            "pages": [
              "guides/manual-tracing",
              "guides/langchain",
              "guides/openai",
              "guides/tree-inspection"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "guides/configuration",
              "guides/production-checklist"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Python reference",
            "pages": [
              "api-reference/introduction",
              "api-reference/python-client",
              "api-reference/langchain-handler"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Platform",
          "href": "https://app.trynexus.io",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Platform",
        "href": "https://app.trynexus.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://app.trynexus.io"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {}
}
